# ============================================================
# GAZI ONLINE — ENVIRONMENT VARIABLES
# ============================================================
# Copy this file to .env and fill in the values
# NEVER commit .env to version control!

# ── SERVER ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── MONGODB ─────────────────────────────────────────────────────
# Get from: https://cloud.mongodb.com/
# Format: mongodb+srv://<user>:<password>@cluster.xxxxx.mongodb.net/gazi-online
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/gazi-online?retryWrites=true&w=majority

# ── JWT ─────────────────────────────────────────────────────────
# Use a long random string (min 32 chars)
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters_long
JWT_EXPIRES_IN=7d

# ── CLOUDINARY ──────────────────────────────────────────────────
# Get from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── RAZORPAY ────────────────────────────────────────────────────
# Get from: https://dashboard.razorpay.com/app/keys
# Use TEST keys for development
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ── CLIENT URL ──────────────────────────────────────────────────
# Frontend URL (for CORS and links in WhatsApp messages)
CLIENT_URL=http://localhost:3000
# Production: CLIENT_URL=https://gazidevs.in

# ── WHATSAPP BUSINESS API (Optional) ────────────────────────────
# Option 1: Meta Business API
# Get from: https://developers.facebook.com/apps/
META_WA_TOKEN=your_meta_whatsapp_token
META_WA_PHONE_ID=your_phone_number_id

# Option 2: Twilio (Alternative)
# Get from: https://console.twilio.com/
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WA_FROM=+14155238886

# ── YOUR BUSINESS WHATSAPP ───────────────────────────────────────
BUSINESS_WHATSAPP=919800000000

# ── ADMIN ───────────────────────────────────────────────────────
# Default admin credentials (change after first login!)
ADMIN_PHONE=9800000000
ADMIN_PASSWORD=Admin@Gazi2024

# ── FIREBASE (Optional — for OTP login) ─────────────────────────
# Get from: https://console.firebase.google.com/
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@your-project.iam.gserviceaccount.com
